# Paddle Sandbox keys for development/testing
# Get your sandbox keys from: https://sandbox-vendors.paddle.com/authentication
# IMPORTANT: Set this to your Paddle client token (test_* for sandbox)
# Leave empty to use mock checkout for development
VITE_PADDLE_CLIENT_TOKEN=

# Paddle Price IDs
# IMPORTANT: These must be different for Pro and Workshop plans!
# Get them from: https://sandbox-vendors.paddle.com/products
VITE_PADDLE_PRO_PRICE_ID=pri_pro_monthly
VITE_PADDLE_WORKSHOP_PRICE_ID=pri_workshop_monthly