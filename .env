# ============================================================
# Paddle Payment Configuration
# ============================================================
# 
# IMPORTANT: You need BOTH client token AND server API key
# 
# 1. VITE_PADDLE_CLIENT_TOKEN → من Paddle Dashboard → Developer Tools → Authentication
#    - يبدأ بـ test_ للساندبوكس أو live_ للإنتاج
#    - يُستخدم في المتصفح (client-side) لفتح Checkout
#
# 2. PADDLE_API_KEY → من Paddle Dashboard → Developer Tools → Authentication
#    - مفتاح API سري (يبدأ بـ pdl_ أو podob_)
#    - يُستخدم في السيرفر للتحقق من Webhooks وإنشاء Portal Sessions
#
# 3. PADDLE_WEBHOOK_SECRET → من Paddle Dashboard → Developer Tools → Webhooks
#    - السر الذي يوقّع به Paddle الـ Webhooks
#    - يُستخدم للتحقق من أن الـ Webhook حقيقي من Paddle
# ============================================================

# Paddle Client Token (public - used in browser for checkout)
# Get from: https://vendors.paddle.com/authentication (production)
# Or: https://sandbox-vendors.paddle.com/authentication (sandbox)
VITE_PADDLE_CLIENT_TOKEN=live_130ae2f79f39d81802e25940530

# Paddle Billing API Key (secret - used server-side)
# Get from: https://vendors.paddle.com/authentication
# IMPORTANT: This is REQUIRED for webhook verification and customer portal
PADDLE_API_KEY="apikey_01kwe9aq42jh9ndbn5ye55ddem"

# Paddle Environment: "sandbox" or "production"
# Must match your PADDLE_API_KEY type
PADDLE_ENVIRONMENT="production"

# Paddle Webhook Secret (for verifying webhook signatures)
# Get from: https://vendors.paddle.com/webhooks (create a webhook endpoint)
# IMPORTANT: This is REQUIRED for webhook verification
PADDLE_WEBHOOK_SECRET="ntf_01kxj3524bf51q6pp02mdgbd6a"

# ============================================================
# Subscription Security
# ============================================================
# CHANGE THIS TO A RANDOM STRING IN PRODUCTION!
SUBSCRIPTION_SECRET=dxfix-prod-secret-2026-magic-cad

# ============================================================
# Paddle Price IDs — Unified naming (NEXT_PUBLIC_ for SSR compat)
# ============================================================
# Get these from: https://vendors.paddle.com/products
# Each plan needs its own price ID
VITE_PADDLE_PRO_PRICE_ID=pri_01kwe9s2cv7fb2x854jkdshw8c
VITE_PADDLE_WORKSHOP_PRICE_ID=pri_01kwe9yxzj0n4njwbncmgt8he0
VITE_PADDLE_ENTERPRISE_PRICE_ID=pri_enterprise_monthly
VITE_PADDLE_PER_FILE_PRICE_ID=pri_01kxwb6fq8bah565m9c84nyj3s

# Paddle price IDs — NEXT_PUBLIC_ variants for SSR environments
NEXT_PUBLIC_PADDLE_PRICE_ONETIME="pri_01kxwb6fq8bah565m9c84nyj3s"
NEXT_PUBLIC_PADDLE_PRICE_WORKSHOP="pri_01kwe9yxzj0n4njwbncmgt8he0"
NEXT_PUBLIC_PADDLE_PRICE_PRO="pri_01kwe9s2cv7fb2x854jkdshw8c"

# ============================================================
# Google AdSense Configuration
# ============================================================
# Google AdSense Publisher ID — replace with your actual ID in production
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-8107838298388341"
VITE_ADSENSE_CLIENT_ID="ca-pub-8107838298388341"

# ============================================================
# Database (for future Postgres migration)
# ============================================================
DATABASE_URL=""